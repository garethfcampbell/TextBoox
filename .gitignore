# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Environment / secrets — never commit these
.env
.env.*
.env.local

# Replit — platform config and internal docs (keep on disk, not in public repo)
.cache/
.local/
.agents/
.upm/
.pythonlibs/
.config/
.replit
.replitignore
replit.md
/.replit-artifact/

# Replit-generated bootstrap (not needed in the repo)
main.py

# Pasted / uploaded context files from agent sessions
attached_assets/

# Generated book output (runtime data, never commit)
artifacts/api-server/output/

# Orval-generated API client code (regenerated via `pnpm --filter @workspace/api-spec run codegen`)
lib/api-client-react/src/generated/
lib/api-zod/src/generated/

# Mockup sandbox component list (auto-generated by the Vite plugin at dev/build time)
artifacts/mockup-sandbox/src/.generated/

# TeX Gyre Termes fonts used by WeasyPrint for PDF generation (downloaded during build)
artifacts/api-server/src/fonts/

# Replit artifact editor metadata (internal, not needed in repo)
artifact.edit.toml
